# Skelly API — local environment (copy to .env and fill in)
# Port the API listens on locally.
PORT=3001

# Restricted app role — subject to Row-Level Security. The running app uses this.
DATABASE_URL="postgresql://skelly_app:skelly_app@localhost:5433/skelly?schema=public"

# Privileged role — used by Prisma for migrations / DDL only (directUrl).
DATABASE_ADMIN_URL="postgresql://skelly:skelly@localhost:5433/skelly?schema=public"

# WorkOS (auth). Get these from the WorkOS dashboard (Staging environment).
WORKOS_CLIENT_ID="client_..."
WORKOS_API_KEY="sk_test_..."            # secret — never commit the real value
WORKOS_REDIRECT_URI="http://localhost:3001/auth/callback"
WORKOS_COOKIE_PASSWORD=""               # a random 32+ char string for sealing sessions
WEB_APP_URL="http://localhost:3000"     # where to send the user after login

