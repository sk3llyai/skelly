# Skelly — shared local environment example. Copy per-app values as needed.
# The local Postgres from docker-compose.yml (host port 5433):
DATABASE_URL="postgresql://skelly_app:skelly_app@localhost:5433/skelly?schema=public"
DATABASE_ADMIN_URL="postgresql://skelly:skelly@localhost:5433/skelly?schema=public"

# Two roles by design:
#   DATABASE_URL        — restricted app role (skelly_app), subject to Row-Level Security (runtime)
#   DATABASE_ADMIN_URL  — privileged role (skelly), used for migrations / DDL only

# Per-app env files:
#   apps/api/.env         (PORT, DATABASE_URL, DATABASE_ADMIN_URL, and later WorkOS keys)
#   apps/web/.env.local   (NEXT_PUBLIC_API_URL)
