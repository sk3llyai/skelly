# Skelly — shared local environment example. Copy per-app values as needed.
# The local Postgres from docker-compose.yml:
DATABASE_URL="postgresql://skelly:skelly@localhost:5432/skelly?schema=public"

# Per-app env files:
#   apps/api/.env         (PORT, DATABASE_URL, and later WorkOS keys)
#   apps/web/.env.local   (NEXT_PUBLIC_API_URL)
